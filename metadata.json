{
  "name": "MemoryPro",
  "desc": "人格核心记忆增强：极简人格化总结版，让 AI 拥有持续且自然的日记感记录。",
  "help": "发送 /强制总结 立即存档。档案存放在 AstrBot/data/memory/ 目录下。",
  "version": "1.0.0",
  "author": "DD",
  "repo": "",
  "priority": 10,
  "config_schema": [
    {
      "item": "threshold",
      "type": "int",
      "default": 50,
      "desc": "自动总结的对话轮数阈值。"
    },
    {
      "item": "fixed_name",
      "type": "string",
      "default": "",
      "desc": "固定的记忆人格名称。"
    },
    {
      "item": "api_url",
      "type": "string",
      "default": "",
      "desc": "（可选）独立总结模型的 API 地址。"
    },
    {
      "item": "api_key",
      "type": "string",
      "default": "",
      "desc": "（可选）独立总结模型的 API KEY。"
    },
    {
      "item": "model_name",
      "type": "string",
      "default": "gpt-4o-mini",
      "desc": "（可选）独立总结使用的模型名称。"
    }
  ]
}